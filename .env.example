AETHERIS_ENVIRONMENT=development
AETHERIS_DEBUG=true
AETHERIS_PROJECT_NAME=Aetheris API
AETHERIS_API_V1_PREFIX=/api/v1
AETHERIS_CORS_ORIGINS=[]

POSTGRES_DB=aetheris
POSTGRES_USER=aetheris
POSTGRES_PASSWORD=change_me_for_local_development

MINIO_ROOT_USER=aetheris
MINIO_ROOT_PASSWORD=change_me_for_local_development

AETHERIS_DATABASE_URL=postgresql+asyncpg://aetheris:change_me_for_local_development@localhost:5432/aetheris
AETHERIS_REDIS_URL=redis://localhost:6379/0
AETHERIS_QDRANT_URL=http://localhost:6333

AETHERIS_MINIO_ENDPOINT=localhost:9000
AETHERIS_MINIO_ACCESS_KEY=aetheris
AETHERIS_MINIO_SECRET_KEY=change_me_for_local_development
AETHERIS_MINIO_SECURE=false
AETHERIS_MINIO_BUCKET=aetheris

AETHERIS_JWT_SECRET_KEY=change_me_to_a_long_random_secret
AETHERIS_JWT_ALGORITHM=HS256
AETHERIS_ACCESS_TOKEN_EXPIRE_MINUTES=30
